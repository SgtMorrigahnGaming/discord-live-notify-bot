# --- Discord (required) ---
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here

# Only needed for src/deploy-commands-guild.js (instant command registration to one test server)
GUILD_ID=

# --- Twitch (required for /twitch commands) ---
# Create an app at https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_POLL_INTERVAL_MS=60000

# --- YouTube (no API key needed — uses public RSS feeds) ---
YOUTUBE_POLL_INTERVAL_MS=300000

# --- Storage ---
DB_PATH=./data/bot.sqlite

# --- Web dashboard (optional) ---

WEB_ENABLED=false

WEB_PORT=3000

# Public URL people actually visit — must match the reverse proxy / domain, include https://, no trailing slash

WEB_PUBLIC_URL=https://bot.morrigahngaming.no

# OAuth2 Client Secret from the SAME Discord application as DISCORD_CLIENT_ID

# (Developer Portal -> your app -> OAuth2 -> Client Secret -- different from the bot token)

DISCORD_CLIENT_SECRET=

# Random long string used to sign session cookies. Generate one with:

#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=