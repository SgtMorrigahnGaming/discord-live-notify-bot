# --- Discord (required) ---
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here

# Only needed for src/deploy-commands-guild.js (instant command registration to one test server)
GUILD_ID=

# --- Twitch (required for /twitch commands) ---
# Create an app at https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_POLL_INTERVAL_MS=60000

# --- YouTube (no API key needed — uses public RSS feeds) ---
YOUTUBE_POLL_INTERVAL_MS=300000

# --- Storage ---
DB_PATH=./data/bot.sqlite
